                "uuid": "6ca02ebb5e5b4ba7a83e37c81d53c44b",
                "template": "BA - MIB - Interfaces MAC",
                "name": "BA - MIB - Interfaces MAC (IF & BRIDGE)",
                "vendor": {
                    "name": "below average",
                    "version": "0.0.0.0"
                },
                "groups": [
                    {
                        "name": "BA/MIBs"
                    }
                ],
                "items": [
                    {
                        "uuid": "fc899d89f8354984b896bbad38c158ac",
                        "name": "Interfaces MAC Count Discovery",
                        "type": "SNMP_AGENT",
                        "snmp_oid": "discovery[{#PORT}, .1.3.6.1.2.1.17.4.3.1.2, {#NAME}, .1.3.6.1.2.1.31.1.1.1.1, {#ALIAS}, .1.3.6.1.2.1.31.1.1.1.18]",
                        "key": "snmp.interfaces.mac.count.discovery.json",
                        "delay": "15m",
                        "history": "0",
                        "value_type": "TEXT",
                        "preprocessing": [
                            {
                                "type": "JAVASCRIPT",
                                "parameters": [
                                    "var data = JSON.parse(value);\nvar ports = {};\nvar results = [];\ndata.forEach(function(macs) {\n    if (macs['{#PORT}'] == undefined) return;\n    if (ports[macs['{#PORT}']] == undefined) {\n        ports[macs['{#PORT}']] = 1;\n    } else {\n        ports[macs['{#PORT}']] += 1;\n    }\n});\ndata.forEach(function(interfaces) {\n        if (interfaces['{#NAME}'] == undefined) return;\n        interfaces['{#MACS}'] = ports[interfaces['{#SNMPINDEX}']];\n        if (interfaces['{#MACS}'] == undefined) interfaces['{#MACS}'] = 0;\n        results.push(interfaces);\n    });\nreturn JSON.stringify(results);"
                                ]
                            }
                        ],
                        "tags": [
                            {
                                "tag": "Item Type",
                                "value": "Discovery"
                            }
                        ]
                    },
                    {
                        "uuid": "9ebe2ba0750e44d6aba6d54dba1504b4",
                        "name": "Interfaces MAC Discovery",
                        "type": "SNMP_AGENT",
                        "snmp_oid": "discovery[{#ADDR}, .1.3.6.1.2.1.17.4.3.1.1, {#IFINDEX}, .1.3.6.1.2.1.17.1.4.1.2, {#PORT}, .1.3.6.1.2.1.17.4.3.1.2, {#NAME}, .1.3.6.1.2.1.31.1.1.1.1, {#ALIAS}, .1.3.6.1.2.1.31.1.1.1.18]",
                        "key": "snmp.interfaces.mac.discovery.json",
                        "delay": "15m",
                        "history": "0",
                        "value_type": "TEXT",
                        "preprocessing": [
                            {
                                "type": "JAVASCRIPT",
                                "parameters": [
                                    "var result = [];\nvar addressReg = /(\"{#ADDR}\":\"..)( )(..)( )(..)( )(..)( )(..)( )(..)( )/g;\nvalue = value.replace(addressReg, '$1:$3:$5:$7:$9:$11');\nvar jvalue = JSON.parse(value);\nvar macToPort = {};\njvalue.forEach(function(address) {\n    if (address['{#ADDR}'] == undefined) return;\n    var newAddrParts = [];\n    var addr = address['{#ADDR}'].toLowerCase();\n    var addrParts = addr.split(':');\n    addrParts.forEach(function(v) {\n        if (v.length == 1) v = '0' + v;\n        newAddrParts.push(v);\n    });\n    var newAddr = newAddrParts.join(':');\n    macToPort[newAddr] = address['{#PORT}'];\n});\nvar portToIfIndex = {};\njvalue.forEach(function(ifindex) {\n    if (ifindex['{#IFINDEX}'] == undefined) return;\n    portToIfIndex[ifindex['{#SNMPINDEX}']] = ifindex['{#IFINDEX}'];\n});\nvar ifIndexToInterface = {};\njvalue.forEach(function(interface) {\n    if (interface['{#NAME}'] == undefined) return;\n    ifIndexToInterface[interface['{#SNMPINDEX}']] = {\n        '{#NAME}': interface['{#NAME}'],\n        '{#ALIAS}': interface['{#ALIAS}']\n    };\n});\nfor (mac in macToPort) {\n    if (portToIfIndex[macToPort[mac]] == undefined) continue;\n    result.push({\n        '{#SNMPINDEX}': mac + ':' + macToPort[mac],\n        '{#MAC}': mac,\n        '{#NAME}': ifIndexToInterface[portToIfIndex[macToPort[mac]]]['{#NAME}'],\n        '{#ALIAS}': ifIndexToInterface[portToIfIndex[macToPort[mac]]]['{#ALIAS}']\n    });\n}\nreturn JSON.stringify(result);"
                                ]
                            }
                        ],
                        "tags": [
                            {
                                "tag": "Item Type",
                                "value": "Discovery"
                            }
                        ]
                    }
                ],
                "discovery_rules": [
                    {
                        "uuid": "b2841a94cb24434798eb25f1bae1be56",
                        "name": "Interfaces MAC Count Discovery",
                        "type": "DEPENDENT",
                        "key": "snmp.interfaces.mac.count.discovery",
                        "filter": {
                            "conditions": [
