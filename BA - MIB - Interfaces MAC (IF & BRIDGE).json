                                "status": "DISABLED",
                                "discover": "NO_DISCOVER",
                                "params": "find(//snmp.interfaces.lldp.desc[{#NAME}],#1,\"regexp\",\"{$INTER_UPLINK_MANAGED_EXCLUDE_LLDP_DESC}\")",
                                "valuemap": {
                                    "name": "Managed Status"
                                },
                                "preprocessing": [
                                    {
                                        "type": "CHECK_NOT_SUPPORTED",
                                        "parameters": [
                                            "-1"
                                        ],
                                        "error_handler": "CUSTOM_VALUE",
                                        "error_handler_params": "0"
                                    }
                                ],
                                "tags": [
                                    {
                                        "tag": "Interface Name",
                                        "value": "{#NAME}"
                                    },
                                    {
